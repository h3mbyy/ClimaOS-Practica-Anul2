<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             x:Class="ClimaOS_Desktop.Pages.DashboardPage"
             BackgroundColor="#0B1120"
             Title="Dashboard Meteo">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Bg">#0B1120</Color>
            <Color x:Key="Card">#0F172A</Color>
            <Color x:Key="Stroke">#1E293B</Color>
            <Color x:Key="Text">#E2E8F0</Color>
            <Color x:Key="Muted">#94A3B8</Color>
            <Color x:Key="Primary">#3B82F6</Color>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource Text}" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="250, *">
        
        <!-- Sidebar -->
        <Border Grid.Column="0" 
                BackgroundColor="{StaticResource Card}" 
                Stroke="{StaticResource Stroke}" 
                StrokeThickness="1" 
                Margin="0,0,1,0">
            <VerticalStackLayout Padding="20" Spacing="15">
                <Label Text="ClimaOS ☁️" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}" Margin="0,0,0,20"/>
                
                <Button Text="🏠 Acasă" BackgroundColor="Transparent" TextColor="{StaticResource Text}" HorizontalOptions="Start"/>
                <Button Text="📅 Prognoză" BackgroundColor="Transparent" TextColor="{StaticResource Text}" HorizontalOptions="Start"/>
                <Button Text="📊 Grafice" BackgroundColor="Transparent" TextColor="{StaticResource Text}" HorizontalOptions="Start"/>
                <Button Text="🗺️ Hartă Radar" BackgroundColor="Transparent" TextColor="{StaticResource Text}" HorizontalOptions="Start"/>
                <Button Text="⚠️ Alerte" BackgroundColor="Transparent" TextColor="{StaticResource Text}" HorizontalOptions="Start"/>
                
                <BoxView HeightRequest="1" Color="{StaticResource Stroke}" Margin="0,20"/>
                
                <Button Text="⚙️ Setări" BackgroundColor="Transparent" TextColor="{StaticResource Text}" HorizontalOptions="Start"/>
                <Button Text="🚪 Deconectare" BackgroundColor="Transparent" TextColor="{StaticResource Muted}" HorizontalOptions="Start" Clicked="OnLogoutClicked"/>
            </VerticalStackLayout>
        </Border>

        <!-- Zona Principală -->
        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Padding="20">
            
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                <VerticalStackLayout Grid.Column="0">
                    <Label x:Name="CurrentDateLabel" Text="Vineri, 7 Mai 2026" FontSize="14" TextColor="{StaticResource Muted}"/>
                    <Label x:Name="LocationLabel" Text="București, România" FontSize="28" FontAttributes="Bold"/>
                </VerticalStackLayout>

                <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                    <Border Stroke="{StaticResource Stroke}" BackgroundColor="{StaticResource Card}" StrokeShape="RoundRectangle 8" Padding="10,5">
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="📍" VerticalOptions="Center"/>
                            <Entry x:Name="SearchEntry" Placeholder="Caută locație..." PlaceholderColor="{StaticResource Muted}" TextColor="{StaticResource Text}" BackgroundColor="Transparent" WidthRequest="200"/>
                        </HorizontalStackLayout>
                    </Border>
                    <Button Text="Caută" BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="8" Clicked="OnSearchClicked"/>
                </HorizontalStackLayout>
            </Grid>

            <!-- Conținut Dashboard -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Spacing="20">
                    
                    <!-- Vremea curentă (Zona de sus) -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="20" RowSpacing="20">
                        <Border Grid.Column="0" BackgroundColor="{StaticResource Card}" Stroke="{StaticResource Stroke}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="20">
                            <HorizontalStackLayout Spacing="20" VerticalOptions="Center">
                                <Label Text="☀️" FontSize="70" VerticalOptions="Center"/>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label x:Name="TemperatureLabel" Text="24°C" FontSize="48" FontAttributes="Bold"/>
                                    <Label x:Name="WeatherConditionLabel" Text="Senin" FontSize="18" TextColor="{StaticResource Primary}"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <Grid Grid.Column="1" RowDefinitions="*, *" ColumnDefinitions="*, *" ColumnSpacing="15" RowSpacing="15">
                            <Border Grid.Row="0" Grid.Column="0" BackgroundColor="{StaticResource Card}" Stroke="{StaticResource Stroke}" StrokeShape="RoundRectangle 12" Padding="15">
                                <VerticalStackLayout>
                                    <Label Text="💧 Umiditate" FontSize="12" TextColor="{StaticResource Muted}"/>
                                    <Label x:Name="HumidityLabel" Text="45%" FontSize="20" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" BackgroundColor="{StaticResource Card}" Stroke="{StaticResource Stroke}" StrokeShape="RoundRectangle 12" Padding="15">
                                <VerticalStackLayout>
                                    <Label Text="💨 Vânt" FontSize="12" TextColor="{StaticResource Muted}"/>
                                    <Label x:Name="WindLabel" Text="12 km/h" FontSize="20" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="0" BackgroundColor="{StaticResource Card}" Stroke="{StaticResource Stroke}" StrokeShape="RoundRectangle 12" Padding="15">
                                <VerticalStackLayout>
                                    <Label Text="🧭 Presiune" FontSize="12" TextColor="{StaticResource Muted}"/>
                                    <Label x:Name="PressureLabel" Text="1012 hPa" FontSize="20" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" BackgroundColor="{StaticResource Card}" Stroke="{StaticResource Stroke}" StrokeShape="RoundRectangle 12" Padding="15">
                                <VerticalStackLayout>
                                    <Label Text="👁️ Vizibilitate" FontSize="12" TextColor="{StaticResource Muted}"/>
                                    <Label x:Name="VisibilityLabel" Text="10 km" FontSize="20" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Prognoza (Placeholder) -->
                    <Border BackgroundColor="{StaticResource Card}" Stroke="{StaticResource Stroke}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="20">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Prognoză 24 ore" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="Aici vor fi adăugate cardurile pentru următoarele ore." TextColor="{StaticResource Muted}"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Grafice -->
                    <Border BackgroundColor="{StaticResource Card}" Stroke="{StaticResource Stroke}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="20">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Evoluție Temperatură (Săptămânal)" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="Graficul va fi activat după stabilizarea randării pe MacCatalyst." TextColor="{StaticResource Muted}"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
            
            <!-- Footer Status -->
            <Label x:Name="LastUpdatedLabel" Grid.Row="2" Text="🔄 Actualizat: acum • Conexiune stabilă OpenWeatherMap" FontSize="12" TextColor="{StaticResource Muted}" HorizontalOptions="Center" Margin="0,10,0,0"/>
        </Grid>
    </Grid>
</ContentPage>