<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:ClimaOS_Desktop.Models"
             x:Class="ClimaOS_Desktop.Pages.Admin.LocationsPage"
             Style="{StaticResource AdminPage}"
             Title="Locații">

    <Grid Padding="20" RowDefinitions="Auto, Auto, *" RowSpacing="14">
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
            <Button Grid.Column="0" Text="← Înapoi" Style="{StaticResource AdminGhostButton}" Clicked="OnBackClicked" />
            <Label Grid.Column="1" Text="Gestionare locații" Style="{StaticResource AdminTitle}" VerticalOptions="Center" />
            <Button Grid.Column="2" Text="+ Adaugă" Style="{StaticResource AdminPrimaryButton}" Clicked="OnAddClicked" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*, 220, Auto, Auto" ColumnSpacing="10">
            <Border Grid.Column="0" Style="{StaticResource AdminFieldBorder}">
                <Entry x:Name="SearchEntry" Style="{StaticResource AdminEntry}"
                       Placeholder="Caută după nume sau țară..." />
            </Border>
            <Border Grid.Column="1" Style="{StaticResource AdminFieldBorder}">
                <Picker x:Name="UserFilterPicker" Style="{StaticResource AdminPicker}" Title="Toți utilizatorii" />
            </Border>
            <Button Grid.Column="2" Text="Caută" Style="{StaticResource AdminPrimaryButton}" Clicked="OnSearchClicked" />
            <Button Grid.Column="3" Text="Reset" Style="{StaticResource AdminGhostButton}" Clicked="OnResetClicked" />
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource AdminCard}" Padding="0">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="2*, 1.2*, 1.4*, 1.6*, 200" Padding="14,12"
                      BackgroundColor="{AppThemeBinding Light={StaticResource AdminFieldLight}, Dark={StaticResource AdminFieldDark}}">
                    <Label Grid.Column="0" Text="Nume" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="Țară" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="2" Text="Coordonate" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="3" Text="Asociat user" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="4" Text="Acțiuni" Style="{StaticResource AdminMuted}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                </Grid>

                <CollectionView Grid.Row="1" x:Name="LocationsList"
                                EmptyView="Nu există locații.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="m:Location">
                            <Grid ColumnDefinitions="2*, 1.2*, 1.4*, 1.6*, 200" Padding="14,10">
                                <Label Grid.Column="0" Text="{Binding Name}" Style="{StaticResource AdminText}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding Country}" Style="{StaticResource AdminMuted}" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding Coordinates}" Style="{StaticResource AdminMuted}" VerticalOptions="Center" />
                                <Label Grid.Column="3" Text="{Binding UserId}" Style="{StaticResource AdminMuted}" VerticalOptions="Center" />
                                <HorizontalStackLayout Grid.Column="4" Spacing="6" HorizontalOptions="End" VerticalOptions="Center">
                                    <Button Text="Editează" WidthRequest="92" HeightRequest="34" FontSize="12"
                                            Style="{StaticResource AdminGhostButton}"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnEditClicked" />
                                    <Button Text="Șterge" WidthRequest="80" HeightRequest="34" FontSize="12"
                                            Style="{StaticResource AdminDangerButton}"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnDeleteClicked" />
                                </HorizontalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
