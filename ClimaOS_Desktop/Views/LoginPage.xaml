<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClimaOS_Desktop.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Style="{StaticResource UserPage}">
    <Grid>
        <BoxView>
            <BoxView.Background>
                <RadialGradientBrush Center="0.5, 0.5" Radius="0.8">
                    <GradientStop Color="{AppThemeBinding Light=#F4FBFF, Dark=#001831}" Offset="0.0" />
                    <GradientStop Color="{AppThemeBinding Light=#EAF6FF, Dark=#141313}" Offset="0.5" />
                    <GradientStop Color="{AppThemeBinding Light=#D8ECFF, Dark=#0e0e0e}" Offset="1.0" />
                </RadialGradientBrush>
            </BoxView.Background>
        </BoxView>
        <VerticalStackLayout Spacing="32" Padding="26,42" VerticalOptions="Center" HorizontalOptions="Center">
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Label Text="☁️" FontSize="36" TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" VerticalOptions="Center"/>
                    <Label Text="ClimaOS" FontSize="36" FontFamily="Hanken Grotesk" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="Autentifică-te în contul tău" FontSize="15" FontFamily="Hanken Grotesk" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource UserSurfaceStrongLight}, Dark=#0DFFFFFF}"
                    Stroke="{AppThemeBinding Light={StaticResource UserStrokeLight}, Dark=#1AFFFFFF}"
                    StrokeThickness="1" Padding="40" StrokeShape="RoundRectangle 24" WidthRequest="460">
                <VerticalStackLayout Spacing="24">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Autentificare" FontFamily="Hanken Grotesk" FontSize="24" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" />
                        <Label Text="Introdu datele pentru a continua." FontFamily="Hanken Grotesk" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="20">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Email" FontFamily="Hanken Grotesk" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource UserSurfaceStrongLight}, Dark=#0DFFFFFF}" Stroke="{AppThemeBinding Light={StaticResource UserStrokeLight}, Dark=#1AFFFFFF}" StrokeThickness="1" Padding="16,0" HeightRequest="48" StrokeShape="RoundRectangle 12">
                                <Entry x:Name="EmailEntry" Placeholder="nume@exemplu.com" Keyboard="Email" ReturnType="Next" TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" PlaceholderColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark=#80ffffff}" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Parolă" FontFamily="Hanken Grotesk" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource UserSurfaceStrongLight}, Dark=#0DFFFFFF}" Stroke="{AppThemeBinding Light={StaticResource UserStrokeLight}, Dark=#1AFFFFFF}" StrokeThickness="1" Padding="16,0" HeightRequest="48" StrokeShape="RoundRectangle 12">
                                <Entry x:Name="PasswordEntry" Placeholder="••••••••" IsPassword="True" ReturnType="Done" Completed="OnPasswordCompleted" TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" PlaceholderColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark=#80ffffff}" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>
                        <Grid HorizontalOptions="Fill" ColumnSpacing="0" ColumnDefinitions="*,Auto">
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="Start" Grid.Column="0">
                                <CheckBox x:Name="RememberMeCheckBox" Color="{StaticResource UserPrimary}" />
                                <Label Text="Ține-mă minte" FontSize="13" FontFamily="Hanken Grotesk" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="Ai uitat parola?" FontSize="13" FontFamily="Hanken Grotesk" TextColor="{StaticResource UserPrimary}" TextDecorations="Underline" VerticalOptions="Center" HorizontalOptions="End" Grid.Column="1">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnResetPasswordTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="12" Margin="0,8,0,0">
                        <Button Text="Autentificare" Clicked="OnLoginClicked" BackgroundColor="{StaticResource UserPrimary}" TextColor="White" FontFamily="Hanken Grotesk" FontAttributes="Bold" CornerRadius="12" HeightRequest="48" />
                        <Button Text="Autentificare cu Google" Clicked="OnGoogleLoginClicked" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1AFFFFFF}" TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" FontFamily="Hanken Grotesk" FontAttributes="Bold" CornerRadius="12" HeightRequest="48" BorderColor="{AppThemeBinding Light={StaticResource UserStrokeLight}, Dark=#33FFFFFF}" BorderWidth="1" />
                    </VerticalStackLayout>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,8,0,0">
                        <Label Text="Nu ai cont?" FontFamily="Hanken Grotesk" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" VerticalOptions="Center" />
                        <Label Text="Înregistrează-te" FontFamily="Hanken Grotesk" FontSize="14" TextColor="{StaticResource UserPrimary}" FontAttributes="Bold" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
