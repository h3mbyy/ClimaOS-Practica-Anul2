<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClimaOS_Desktop.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#141313">

    <!-- Design System Colors and Styles -->
    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="OnSurfaceVariant">#c4c7c8</Color>
            <Color x:Key="SecondaryContainer">#4b8eff</Color>
            
            <Style x:Key="GlassEntry" TargetType="Entry">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="PlaceholderColor" Value="#80c4c7c8" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="FontSize" Value="17" />
                <Setter Property="FontFamily" Value="Hanken Grotesk" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!-- Atmospheric Background -->
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#091829" Offset="0.0" />
                    <GradientStop Color="#11365C" Offset="0.45" />
                    <GradientStop Color="#1F4C73" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <BoxView Opacity="0.9">
            <BoxView.Background>
                <RadialGradientBrush Center="0.85,0.15" Radius="0.8">
                    <GradientStop Color="#55FFD27A" Offset="0.0" />
                    <GradientStop Color="#00000000" Offset="1.0" />
                </RadialGradientBrush>
            </BoxView.Background>
        </BoxView>
        
        <!-- Dark Gradient Overlay -->
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#4D141313" Offset="0.0" />
                    <GradientStop Color="#80141313" Offset="0.5" />
                    <GradientStop Color="#CC141313" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Main Layout Split (Sidebar + Content) -->
        <Grid ColumnDefinitions="256, *">
            
            <!-- Sidebar Navigation -->
            <Border Grid.Column="0" 
                    Stroke="#1AFFFFFF" 
                    StrokeThickness="1"
                    BackgroundColor="#66000000" 
                    Padding="24"
                    StrokeShape="Rectangle">
                
                <Grid RowDefinitions="Auto, *, Auto">
                    <!-- Logo Area -->
                    <HorizontalStackLayout Grid.Row="0" Spacing="8" Margin="0,0,0,40">
                        <Label Text="☁️" FontSize="24" TextColor="White" VerticalOptions="Center"/>
                        <Label Text="ClimaOS" FontSize="24" FontFamily="Hanken Grotesk" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    
                    <!-- Nav Links -->
                    <VerticalStackLayout Grid.Row="1" Spacing="8">
                        <Border BackgroundColor="#1AFFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="16,12">
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="🚪" FontSize="18" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="Autentificare" FontFamily="Hanken Grotesk" FontSize="17" TextColor="White" FontAttributes="Bold" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                        
                        <HorizontalStackLayout Spacing="12" Padding="16,12" Opacity="0.7">
                            <Label Text="📊" FontSize="18" TextColor="White" VerticalOptions="Center"/>
                            <Label Text="Dashboard" FontFamily="Hanken Grotesk" FontSize="17" TextColor="White" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        
                        <HorizontalStackLayout Spacing="12" Padding="16,12" Opacity="0.7">
                            <Label Text="🗺️" FontSize="18" TextColor="White" VerticalOptions="Center"/>
                            <Label Text="Hărți" FontFamily="Hanken Grotesk" FontSize="17" TextColor="White" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        
                        <HorizontalStackLayout Spacing="12" Padding="16,12" Opacity="0.7">
                            <Label Text="📈" FontSize="18" TextColor="White" VerticalOptions="Center"/>
                            <Label Text="Analize" FontFamily="Hanken Grotesk" FontSize="17" TextColor="White" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    
                    <!-- Bottom Link -->
                    <VerticalStackLayout Grid.Row="2">
                        <BoxView HeightRequest="1" Color="#1AFFFFFF" Margin="0,0,0,24" />
                        <HorizontalStackLayout Spacing="12" Padding="16,12" Opacity="0.7">
                            <Label Text="⚙️" FontSize="18" TextColor="White" VerticalOptions="Center"/>
                            <Label Text="Setări" FontFamily="Hanken Grotesk" FontSize="17" TextColor="White" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <ScrollView Grid.Column="1">
                <VerticalStackLayout Spacing="0" Padding="40" HorizontalOptions="Center" VerticalOptions="Center">
                    
                    <!-- Brand Header Centered -->
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center" Margin="0,0,0,32">
                        <Label Text="☁️" FontSize="60" TextColor="White" HorizontalOptions="Center" Margin="0,0,0,16"/>
                        <Label Text="ClimaOS" FontSize="32" FontFamily="Hanken Grotesk" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                        <Label Text="Premium Weather Forecasting" FontSize="14" FontFamily="Hanken Grotesk" TextColor="{StaticResource OnSurfaceVariant}" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Split Login/Signup Container (Glassmorphism) -->
                    <Border Stroke="#33FFFFFF" 
                            StrokeThickness="1"
                            BackgroundColor="#1AFFFFFF" 
                            StrokeShape="RoundRectangle 12"
                            WidthRequest="800"
                            HorizontalOptions="Center">
                        
                        <!-- Simulating BoxShadow -->
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,15" Radius="30" Opacity="0.5" />
                        </Border.Shadow>
                        
                        <Grid ColumnDefinitions="*, *">
                            
                            <!-- Left Side: Login Form -->
                            <VerticalStackLayout Grid.Column="0" Spacing="24" Padding="40">
                                
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Utilizator" FontSize="14" FontFamily="Hanken Grotesk" TextColor="{StaticResource OnSurfaceVariant}" />
                                    <Border Stroke="#33FFFFFF" StrokeThickness="1" BackgroundColor="#0DFFFFFF" StrokeShape="RoundRectangle 4" Padding="16,4">
                                        <Entry x:Name="EmailEntry" 
                                               Style="{StaticResource GlassEntry}" 
                                               Placeholder="info@example.com" 
                                               Keyboard="Email" 
                                               ReturnType="Next" />
                                    </Border>
                                </VerticalStackLayout>
                                
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Parolă" FontSize="14" FontFamily="Hanken Grotesk" TextColor="{StaticResource OnSurfaceVariant}" />
                                    <Border Stroke="#33FFFFFF" StrokeThickness="1" BackgroundColor="#0DFFFFFF" StrokeShape="RoundRectangle 4" Padding="16,4">
                                        <Entry x:Name="PasswordEntry" 
                                               Style="{StaticResource GlassEntry}" 
                                               Placeholder="••••••••" 
                                               IsPassword="True" 
                                               ReturnType="Done" 
                                               Completed="OnPasswordCompleted" />
                                    </Border>
                                </VerticalStackLayout>
                                
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox x:Name="RememberMeCheckBox" Color="{StaticResource SecondaryContainer}" />
                                    <Label Text="Ține-mă minte" FontSize="14" FontFamily="Hanken Grotesk" TextColor="{StaticResource OnSurfaceVariant}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                
                                <VerticalStackLayout Spacing="16">
                                    <Button Text="Autentificare" 
                                            Clicked="OnLoginClicked"
                                            BackgroundColor="#005a8c" 
                                            TextColor="White" 
                                            FontFamily="Hanken Grotesk" 
                                            FontSize="17" 
                                            FontAttributes="Bold"
                                            CornerRadius="4" 
                                            HeightRequest="48" />
                                            
                                    <Button Text="Autentificare cu Google" 
                                            Clicked="OnGoogleLoginClicked"
                                            BackgroundColor="White" 
                                            TextColor="#1a1c1c" 
                                            FontFamily="Hanken Grotesk" 
                                            FontSize="17" 
                                            FontAttributes="Bold"
                                            CornerRadius="4" 
                                            HeightRequest="48" />
                                </VerticalStackLayout>
                                
                                <FlexLayout JustifyContent="SpaceBetween" Margin="0,16,0,0">
                                    <Label Text="Resetează parola" FontSize="14" FontFamily="Hanken Grotesk" TextColor="#adc6ff" TextDecorations="Underline" VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnResetPasswordTapped" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Border Stroke="#33FFFFFF" StrokeThickness="1" BackgroundColor="#0DFFFFFF" StrokeShape="RoundRectangle 4" Padding="8,4">
                                        <Label Text="ro ▼" FontSize="14" TextColor="White" VerticalOptions="Center" />
                                    </Border>
                                </FlexLayout>

                            </VerticalStackLayout>
                            
                            <!-- Middle Divider -->
                            <BoxView Grid.Column="0" HorizontalOptions="End" WidthRequest="1" Color="#1AFFFFFF" />
                            
                            <!-- Right Side: Sign Up -->
                            <VerticalStackLayout Grid.Column="1" Spacing="24" Padding="40" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label Text="Nu ai cont?" FontSize="24" FontFamily="Hanken Grotesk" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                                
                                <Button Text="Înregistrează-te" 
                                        Clicked="OnRegisterTapped"
                                        BackgroundColor="#ffb868" 
                                        TextColor="#673d00" 
                                        FontFamily="Hanken Grotesk" 
                                        FontSize="17" 
                                        FontAttributes="Bold"
                                        CornerRadius="4" 
                                        HeightRequest="48"
                                        WidthRequest="240" />
                                        
                                <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,16,0,0">
                                    <Label Text="Prețuri" FontSize="14" FontFamily="Hanken Grotesk" TextColor="#adc6ff" HorizontalOptions="Center" TextDecorations="Underline"/>
                                    <Label Text="Mai multe info" FontSize="14" FontFamily="Hanken Grotesk" TextColor="#adc6ff" HorizontalOptions="Center" TextDecorations="Underline"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
