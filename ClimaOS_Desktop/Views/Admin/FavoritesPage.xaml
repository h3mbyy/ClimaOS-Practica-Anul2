<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:ClimaOS_Desktop.Models"
             x:Class="ClimaOS_Desktop.Views.Admin.FavoritesPage"
             Style="{StaticResource AdminPage}"
             Title="Favorite">

    <Grid Padding="20" RowDefinitions="Auto, Auto, *" RowSpacing="14">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
            <Button Grid.Column="0" Text="← Inapoi" Style="{StaticResource AdminGhostButton}" Clicked="OnBackClicked" />
            <Label Grid.Column="1" Text="Favorite utilizatori" Style="{StaticResource AdminTitle}" VerticalOptions="Center" />
            <Button Grid.Column="2" Text="+ Adauga" Style="{StaticResource AdminPrimaryButton}" Clicked="OnAddClicked" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">
            <Border Grid.Column="0" Style="{StaticResource AdminFieldBorder}">
                <Entry x:Name="SearchEntry" Style="{StaticResource AdminEntry}"
                       Placeholder="Cauta dupa utilizator sau locatie..." />
            </Border>
            <Button Grid.Column="1" Text="Cauta" Style="{StaticResource AdminPrimaryButton}" Clicked="OnSearchClicked" />
            <Button Grid.Column="2" Text="Reset" Style="{StaticResource AdminGhostButton}" Clicked="OnResetClicked" />
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource AdminCard}" Padding="0">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="2*, 2*, 1.2*, 200" Padding="14,12"
                      BackgroundColor="{AppThemeBinding Light={StaticResource AdminFieldLight}, Dark={StaticResource AdminFieldDark}}">
                    <Label Grid.Column="0" Text="Utilizator" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="Locatie" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="2" Text="Adaugat" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="3" Text="Actiuni" Style="{StaticResource AdminMuted}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                </Grid>

                <CollectionView Grid.Row="1" x:Name="FavoritesList"
                                EmptyView="Nu exista favorite.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="m:UserFavorite">
                            <Grid ColumnDefinitions="2*, 2*, 1.2*, 200" Padding="14,10">
                                <Label Grid.Column="0" Text="{Binding UserEmail}" Style="{StaticResource AdminText}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding LocationDisplay}" Style="{StaticResource AdminMuted}" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding AddedAtDisplay}" Style="{StaticResource AdminMuted}" VerticalOptions="Center" />
                                <HorizontalStackLayout Grid.Column="3" Spacing="6" HorizontalOptions="End" VerticalOptions="Center">
                                    <Button Text="Sterge" WidthRequest="80" HeightRequest="34" FontSize="12"
                                            Style="{StaticResource AdminDangerButton}"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnDeleteClicked" />
                                </HorizontalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
