<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:ClimaOS_Desktop.Models"
             x:Class="ClimaOS_Desktop.Views.Admin.LogsPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Style="{StaticResource AdminPage}">
    <Grid>
        <!-- Atmospheric Background -->
        <BoxView>
            <BoxView.Background>
                <RadialGradientBrush Center="0.5, 0.5" Radius="0.8">
                    <GradientStop Color="{AppThemeBinding Light=#F4F9FF, Dark=#141a2e}" Offset="0.0" />
                    <GradientStop Color="{AppThemeBinding Light=#EEF6FF, Dark=#141313}" Offset="0.5" />
                    <GradientStop Color="{AppThemeBinding Light=#DBEAFE, Dark=#0e0e0e}" Offset="1.0" />
                </RadialGradientBrush>
            </BoxView.Background>
        </BoxView>

        <Grid ColumnDefinitions="260, *">
            
            <!-- Sidebar Navigation -->
            <Border Grid.Column="0"
                    Style="{StaticResource AdminSidebar}">
                
                <Grid RowDefinitions="Auto, *, Auto">
                    <!-- Logo -->
                    <HorizontalStackLayout Grid.Row="0" Spacing="12" Margin="16,0,0,40">
                        <Label Text="☁️" FontSize="28" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                        <Label Text="ClimaOS" FontSize="24" FontFamily="Hanken Grotesk" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    
                    <!-- Navigation Links -->
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout Spacing="4">
                            
                            <Border BackgroundColor="Transparent" StrokeThickness="0" Padding="16,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnBackClicked"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="16" Opacity="0.7">
                                    <Label Text="📊" FontSize="22" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                    <Label Text="Dashboard" FontFamily="Hanken Grotesk" FontSize="17" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                            <Border BackgroundColor="Transparent" StrokeThickness="0" Padding="16,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnUsersClicked"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="16" Opacity="0.7">
                                    <Label Text="👥" FontSize="22" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                    <Label Text="Utilizatori" FontFamily="Hanken Grotesk" FontSize="17" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                            <Border BackgroundColor="Transparent" StrokeThickness="0" Padding="16,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLocationsClicked"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="16" Opacity="0.7">
                                    <Label Text="📡" FontSize="22" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                    <Label Text="Stații" FontFamily="Hanken Grotesk" FontSize="17" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                            
                            <Border BackgroundColor="Transparent" StrokeThickness="0" Padding="16,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAlertsClicked"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="16" Opacity="0.7">
                                    <Label Text="⚠️" FontSize="22" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                    <Label Text="Alerte Meteo" FontFamily="Hanken Grotesk" FontSize="17" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                            <Border BackgroundColor="Transparent" StrokeThickness="0" Padding="16,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnReportsClicked"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="16" Opacity="0.7">
                                    <Label Text="📄" FontSize="22" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                    <Label Text="Rapoarte" FontFamily="Hanken Grotesk" FontSize="17" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                            <Border BackgroundColor="Transparent" StrokeThickness="0" Padding="16,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFavoritesClicked"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="16" Opacity="0.7">
                                    <Label Text="⭐" FontSize="22" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                    <Label Text="Favorite" FontFamily="Hanken Grotesk" FontSize="17" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                            <Border BackgroundColor="#1A4b8eff" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="16,12">
                                <HorizontalStackLayout Spacing="16">
                                    <Label Text="📜" FontSize="22" TextColor="#4b8eff" VerticalOptions="Center"/>
                                    <Label Text="Jurnale (Logs)" FontFamily="Hanken Grotesk" FontSize="17" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                        </VerticalStackLayout>
                    </ScrollView>

                    <!-- Bottom Actions -->
                    <VerticalStackLayout Grid.Row="2" Spacing="8">
                        
                        <Border BackgroundColor="Transparent" StrokeThickness="0" Padding="16,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSettingsClicked"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="16" Opacity="0.7">
                                <Label Text="⚙️" FontSize="20" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                <Label Text="Setări" FontFamily="Hanken Grotesk" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <Border BackgroundColor="Transparent" StrokeThickness="0" Padding="16,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLogoutClicked"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="16" Opacity="0.7">
                                <Label Text="🚪" FontSize="20" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                                <Label Text="Deconectare" FontFamily="Hanken Grotesk" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1" RowDefinitions="80, *">
                
                <Border Grid.Row="0" StrokeThickness="0" StrokeShape="Rectangle"
                        BackgroundColor="{AppThemeBinding Light={StaticResource AdminTopBarLight}, Dark={StaticResource AdminTopBarDark}}" Padding="32,0" VerticalOptions="Center">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <HorizontalStackLayout Grid.Column="1" Spacing="16">
                            <Label Text="🔔" FontSize="22" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center" Opacity="0.7" />
                            <Label Text="⚙️" FontSize="22" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center" Opacity="0.7" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>
                
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Padding="32" Spacing="32" MaximumWidthRequest="1400" HorizontalOptions="Start">
                        
                        <!-- Header and Search -->
                        <Grid ColumnDefinitions="*, Auto" RowSpacing="16" ColumnSpacing="16">
                            <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                <Label Text="Jurnale de Sistem" FontFamily="Hanken Grotesk" FontSize="32" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" />
                                <Label Text="Monitorizarea activității și cererilor API." FontFamily="Hanken Grotesk" FontSize="17"
                                       TextColor="{AppThemeBinding Light={StaticResource AdminMutedLight}, Dark={StaticResource AdminMutedDark}}" />
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="12">
                                <Border Style="{StaticResource GlassPanel}" Padding="16,0" HeightRequest="44" WidthRequest="260" StrokeShape="RoundRectangle 22">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="🔍" VerticalOptions="Center" />
                                        <Entry x:Name="SearchEntry" Placeholder="Caută locație sau utilizator..." TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" PlaceholderColor="{AppThemeBinding Light={StaticResource AdminMutedLight}, Dark=#80ffffff}" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" WidthRequest="180" />
                                    </HorizontalStackLayout>
                                </Border>
                                
                                <Border Style="{StaticResource GlassPanel}" Padding="16,0" HeightRequest="44" StrokeShape="RoundRectangle 22">
                                    <Picker x:Name="StatusPicker" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" Title="Orice status" TitleColor="{AppThemeBinding Light={StaticResource AdminMutedLight}, Dark=#80ffffff}" BackgroundColor="Transparent" VerticalOptions="Center" FontSize="14" FontFamily="Hanken Grotesk">
                                        <Picker.Items>
                                            <x:String>Toate</x:String>
                                            <x:String>succes</x:String>
                                            <x:String>eroare</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </Border>

                                <Button Text="Caută" Clicked="OnSearchClicked" BackgroundColor="{AppThemeBinding Light=#EAF2FF, Dark=#1AFFFFFF}" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" CornerRadius="22" HeightRequest="44" />
                                <Button Text="Reset" Clicked="OnResetClicked" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light={StaticResource AdminMutedLight}, Dark={StaticResource AdminMutedDark}}" CornerRadius="22" HeightRequest="44" />
                                <Button Text="+ Log Nou" Clicked="OnAddClicked" BackgroundColor="#4b8eff" TextColor="#00285c" FontFamily="Hanken Grotesk" FontAttributes="Bold" CornerRadius="22" HeightRequest="44" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="12" HorizontalOptions="End">
                                <Border Style="{StaticResource GlassPanel}" Padding="16,0" HeightRequest="44" WidthRequest="190" StrokeShape="RoundRectangle 22">
                                    <Entry x:Name="ExactUserEntry" Placeholder="Utilizator exact" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" PlaceholderColor="{AppThemeBinding Light={StaticResource AdminMutedLight}, Dark=#80ffffff}" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                                </Border>
                                <Border Style="{StaticResource GlassPanel}" Padding="16,0" HeightRequest="44" WidthRequest="190" StrokeShape="RoundRectangle 22">
                                    <Entry x:Name="ExactLocationEntry" Placeholder="Locație exactă" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" PlaceholderColor="{AppThemeBinding Light={StaticResource AdminMutedLight}, Dark=#80ffffff}" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                                </Border>
                                <DatePicker x:Name="FromPicker" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" BackgroundColor="{AppThemeBinding Light=#EAF2FF, Dark=#1AFFFFFF}" />
                                <DatePicker x:Name="ToPicker" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" BackgroundColor="{AppThemeBinding Light=#EAF2FF, Dark=#1AFFFFFF}" />
                                <Button Text="Curăță 30+ zile" Clicked="OnClearOldClicked" BackgroundColor="#ffb4ab" TextColor="#690005" FontAttributes="Bold" CornerRadius="22" HeightRequest="44" />
                            </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Logs Grid -->
                        <CollectionView x:Name="LogsList" EmptyView="Nu există jurnale înregistrate.">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="3" VerticalItemSpacing="16" HorizontalItemSpacing="16" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="m:SystemLog">
                                    <Border Style="{StaticResource GlassPanel}" Padding="24">
                                        <VerticalStackLayout Spacing="16">
                                            
                                            <Grid ColumnDefinitions="*, Auto">
                                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                    <HorizontalStackLayout Spacing="6">
                                                        <Label Text="🟢" FontSize="12" VerticalOptions="Center">
                                                            <Label.Triggers>
                                                                <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="succes">
                                                                    <Setter Property="IsVisible" Value="True" />
                                                                </DataTrigger>
                                                                <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="eroare">
                                                                    <Setter Property="IsVisible" Value="False" />
                                                                </DataTrigger>
                                                            </Label.Triggers>
                                                        </Label>
                                                        <Label Text="🔴" FontSize="12" IsVisible="False" VerticalOptions="Center">
                                                            <Label.Triggers>
                                                                <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="eroare">
                                                                    <Setter Property="IsVisible" Value="True" />
                                                                </DataTrigger>
                                                            </Label.Triggers>
                                                        </Label>
                                                        <Label Text="{Binding StatusDisplay}" FontFamily="Hanken Grotesk" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" VerticalOptions="Center" />
                                                    </HorizontalStackLayout>
                                                    <Label Text="{Binding LocationName}" FontFamily="Hanken Grotesk" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" />
                                                    <Label Text="{Binding RequestedBy}" FontFamily="Hanken Grotesk" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource AdminMutedLight}, Dark={StaticResource AdminMutedDark}}" />
                                                </VerticalStackLayout>
                                                
                                                <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Start">
                                                    <Button Text="❌" CommandParameter="{Binding .}" Clicked="OnDeleteClicked" BackgroundColor="Transparent" Padding="0" WidthRequest="32" HeightRequest="32" />
                                                </HorizontalStackLayout>
                                            </Grid>
                                            
                                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource AdminDividerLight}, Dark=#1AFFFFFF}" />
                                            
                                            <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                                                <Label Grid.Column="0" Text="Data: " FontFamily="Hanken Grotesk" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource AdminMutedLight}, Dark={StaticResource AdminMutedDark}}" />
                                                <Label Grid.Column="1" Text="{Binding LogDateDisplay}" FontFamily="Hanken Grotesk" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" />
                                                
                                                <Label Grid.Column="2" Text="Timp răspuns: " FontFamily="Hanken Grotesk" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource AdminMutedLight}, Dark={StaticResource AdminMutedDark}}" />
                                                <Label Grid.Column="3" Text="{Binding ResponseTimeMs, StringFormat='{0} ms'}" FontFamily="Hanken Grotesk" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource AdminTextLight}, Dark=White}" />
                                            </Grid>
                                            
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
