<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:ClimaOS_Desktop.Models"
             x:Class="ClimaOS_Desktop.Views.Admin.LogsPage"
             Style="{StaticResource AdminPage}"
             Title="Jurnale">

    <Grid Padding="20" RowDefinitions="Auto, Auto, *" RowSpacing="14">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
            <Button Grid.Column="0" Text="← Inapoi" Style="{StaticResource AdminGhostButton}" Clicked="OnBackClicked" />
            <Label Grid.Column="1" Text="Jurnale sistem" Style="{StaticResource AdminTitle}" VerticalOptions="Center" />
            <Button Grid.Column="2" Text="+ Adauga" Style="{StaticResource AdminPrimaryButton}" Clicked="OnAddClicked" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*, 160, Auto, Auto" ColumnSpacing="10">
            <Border Grid.Column="0" Style="{StaticResource AdminFieldBorder}">
                <Entry x:Name="SearchEntry" Style="{StaticResource AdminEntry}"
                       Placeholder="Cauta dupa utilizator sau locatie..." />
            </Border>
            <Border Grid.Column="1" Style="{StaticResource AdminFieldBorder}">
                <Picker x:Name="StatusPicker" Style="{StaticResource AdminPicker}" Title="Toate">
                    <Picker.Items>
                        <x:String>Toate</x:String>
                        <x:String>succes</x:String>
                        <x:String>eroare</x:String>
                    </Picker.Items>
                </Picker>
            </Border>
            <Button Grid.Column="2" Text="Cauta" Style="{StaticResource AdminPrimaryButton}" Clicked="OnSearchClicked" />
            <Button Grid.Column="3" Text="Reset" Style="{StaticResource AdminGhostButton}" Clicked="OnResetClicked" />
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource AdminCard}" Padding="0">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="2*, 1.4*, 1*, 1.2*, 200" Padding="14,12"
                      BackgroundColor="{AppThemeBinding Light={StaticResource AdminFieldLight}, Dark={StaticResource AdminFieldDark}}">
                    <Label Grid.Column="0" Text="Locatie" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="Solicitat de" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="2" Text="Status" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="3" Text="Timp (ms)" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="4" Text="Actiuni" Style="{StaticResource AdminMuted}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                </Grid>

                <CollectionView Grid.Row="1" x:Name="LogsList"
                                EmptyView="Nu exista jurnale.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="m:SystemLog">
                            <Grid ColumnDefinitions="2*, 1.4*, 1*, 1.2*, 200" Padding="14,10">
                                <Label Grid.Column="0" Text="{Binding LocationName}" Style="{StaticResource AdminText}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding RequestedBy}" Style="{StaticResource AdminMuted}" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding StatusDisplay}" Style="{StaticResource AdminMuted}" VerticalOptions="Center" />
                                <Label Grid.Column="3" Text="{Binding ResponseTimeMs}" Style="{StaticResource AdminMuted}" VerticalOptions="Center" />
                                <HorizontalStackLayout Grid.Column="4" Spacing="6" HorizontalOptions="End" VerticalOptions="Center">
                                    <Button Text="Sterge" WidthRequest="80" HeightRequest="34" FontSize="12"
                                            Style="{StaticResource AdminDangerButton}"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnDeleteClicked" />
                                </HorizontalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
