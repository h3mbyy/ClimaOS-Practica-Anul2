<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:ClimaOS_Desktop.Models"
             x:Class="ClimaOS_Desktop.Views.Admin.UsersPage"
             Style="{StaticResource AdminPage}"
             Title="Utilizatori">

    <Grid Padding="20" RowDefinitions="Auto, Auto, *" RowSpacing="14">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
            <Button Grid.Column="0" Text="← Înapoi" Style="{StaticResource AdminGhostButton}" Clicked="OnBackClicked" />
            <Label Grid.Column="1" Text="Gestionare utilizatori" Style="{StaticResource AdminTitle}" VerticalOptions="Center" />
            <Button Grid.Column="2" Text="+ Adaugă" Style="{StaticResource AdminPrimaryButton}" Clicked="OnAddClicked" />
        </Grid>

        <!-- Filtre -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 200, Auto, Auto" ColumnSpacing="10">
            <Border Grid.Column="0" Style="{StaticResource AdminFieldBorder}">
                <Entry x:Name="SearchEntry" Style="{StaticResource AdminEntry}"
                       Placeholder="Caută după nume sau email..." />
            </Border>
            <Border Grid.Column="1" Style="{StaticResource AdminFieldBorder}">
                <Picker x:Name="RolePicker" Style="{StaticResource AdminPicker}" Title="Toate rolurile">
                    <Picker.Items>
                        <x:String>Toate rolurile</x:String>
                        <x:String>Administratori</x:String>
                        <x:String>Utilizatori</x:String>
                    </Picker.Items>
                </Picker>
            </Border>
            <Button Grid.Column="2" Text="Caută" Style="{StaticResource AdminPrimaryButton}" Clicked="OnSearchClicked" />
            <Button Grid.Column="3" Text="Reset" Style="{StaticResource AdminGhostButton}" Clicked="OnResetClicked" />
        </Grid>

        <!-- Listă -->
        <Border Grid.Row="2" Style="{StaticResource AdminCard}" Padding="0">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="2*, 3*, 1.2*, 1.5*, 200" Padding="14,12"
                      BackgroundColor="{AppThemeBinding Light={StaticResource AdminFieldLight}, Dark={StaticResource AdminFieldDark}}">
                    <Label Grid.Column="0" Text="Nume" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="Email" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="2" Text="Rol" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="3" Text="Creat" Style="{StaticResource AdminMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="4" Text="Acțiuni" Style="{StaticResource AdminMuted}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                </Grid>

                <CollectionView Grid.Row="1" x:Name="UsersList"
                                EmptyView="Nu există utilizatori care să corespundă filtrelor.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="m:User">
                            <Grid ColumnDefinitions="2*, 3*, 1.2*, 1.5*, 200" Padding="14,10" RowSpacing="0">
                                <Label Grid.Column="0" Text="{Binding Name}" Style="{StaticResource AdminText}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding Email}" Style="{StaticResource AdminMuted}" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding RoleDisplay}" Style="{StaticResource AdminMuted}" VerticalOptions="Center" />
                                <Label Grid.Column="3" Text="{Binding CreatedAtDisplay}" Style="{StaticResource AdminMuted}" VerticalOptions="Center" />
                                <HorizontalStackLayout Grid.Column="4" Spacing="6" HorizontalOptions="End" VerticalOptions="Center">
                                    <Button Text="Editează" WidthRequest="92" HeightRequest="34" FontSize="12"
                                            Style="{StaticResource AdminGhostButton}"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnEditClicked" />
                                    <Button Text="Șterge" WidthRequest="80" HeightRequest="34" FontSize="12"
                                            Style="{StaticResource AdminDangerButton}"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnDeleteClicked" />
                                </HorizontalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
