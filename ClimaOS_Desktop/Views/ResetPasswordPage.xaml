<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClimaOS_Desktop.Views.ResetPasswordPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Style="{StaticResource UserPage}">

    <Grid>
        <!-- Atmospheric Background -->
        <BoxView>
            <BoxView.Background>
                <RadialGradientBrush Center="0.5, 0.5" Radius="0.8">
                    <GradientStop Color="{AppThemeBinding Light=#F4FBFF, Dark=#001831}" Offset="0.0" />
                    <GradientStop Color="{AppThemeBinding Light=#EAF6FF, Dark=#141313}" Offset="0.5" />
                    <GradientStop Color="{AppThemeBinding Light=#D8ECFF, Dark=#0e0e0e}" Offset="1.0" />
                </RadialGradientBrush>
            </BoxView.Background>
        </BoxView>

        <VerticalStackLayout Spacing="32" Padding="26,42" VerticalOptions="Center" HorizontalOptions="Center">
            
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Label Text="☁️" FontSize="36" TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" VerticalOptions="Center"/>
                    <Label Text="ClimaOS" FontSize="36" FontFamily="Hanken Grotesk" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="Resetare parolă" FontSize="15" FontFamily="Hanken Grotesk" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Border BackgroundColor="{AppThemeBinding Light={StaticResource UserSurfaceStrongLight}, Dark=#0DFFFFFF}"
                    Stroke="{AppThemeBinding Light={StaticResource UserStrokeLight}, Dark=#1AFFFFFF}"
                    StrokeThickness="1" Padding="40" StrokeShape="RoundRectangle 24" WidthRequest="460">
                <Grid>
                    
                    <!-- PASUL 1: Solicitare Cod -->
                    <VerticalStackLayout x:Name="Step1View" Spacing="24" IsVisible="True">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Pasul 1 din 3" FontFamily="Hanken Grotesk" FontSize="14" TextColor="{StaticResource UserPrimary}" FontAttributes="Bold" />
                            <Label Text="Introdu adresa de email asociată contului tău pentru a primi un cod de resetare." FontFamily="Hanken Grotesk" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" />
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Email" FontFamily="Hanken Grotesk" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource UserSurfaceStrongLight}, Dark=#0DFFFFFF}" Stroke="{AppThemeBinding Light={StaticResource UserStrokeLight}, Dark=#1AFFFFFF}" StrokeThickness="1" Padding="16,0" HeightRequest="48" StrokeShape="RoundRectangle 12">
                                <Entry x:Name="EmailEntry" Placeholder="nume@exemplu.com" Keyboard="Email" ReturnType="Next" TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" PlaceholderColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark=#80ffffff}" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>
                        
                        <Button x:Name="RequestCodeButton" Text="Trimite codul" Clicked="OnRequestCodeClicked" BackgroundColor="{StaticResource UserPrimary}" TextColor="White" FontFamily="Hanken Grotesk" FontAttributes="Bold" CornerRadius="12" HeightRequest="48" />
                    </VerticalStackLayout>

                    <!-- PASUL 2: Verificare Cod -->
                    <VerticalStackLayout x:Name="Step2View" Spacing="24" IsVisible="False">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Pasul 2 din 3" FontFamily="Hanken Grotesk" FontSize="14" TextColor="{StaticResource UserPrimary}" FontAttributes="Bold" />
                            <Label Text="Introdu codul de 6 cifre primit pe email." FontFamily="Hanken Grotesk" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" />
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Cod de verificare" FontFamily="Hanken Grotesk" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource UserSurfaceStrongLight}, Dark=#0DFFFFFF}" Stroke="{AppThemeBinding Light={StaticResource UserStrokeLight}, Dark=#1AFFFFFF}" StrokeThickness="1" Padding="16,0" HeightRequest="48" StrokeShape="RoundRectangle 12">
                                <Entry x:Name="CodeEntry" Placeholder="000000" Keyboard="Numeric" MaxLength="6" ReturnType="Next" TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" PlaceholderColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark=#80ffffff}" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>
                        
                        <Button x:Name="VerifyCodeButton" Text="Verifică codul" Clicked="OnVerifyCodeClicked" BackgroundColor="{StaticResource UserPrimary}" TextColor="White" FontFamily="Hanken Grotesk" FontAttributes="Bold" CornerRadius="12" HeightRequest="48" />
                        <Button x:Name="ResendCodeButton" Text="Retrimite codul" Clicked="OnResendCodeClicked" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1AFFFFFF}" TextColor="{StaticResource UserPrimary}" FontFamily="Hanken Grotesk" FontAttributes="Bold" CornerRadius="12" HeightRequest="48" BorderColor="{AppThemeBinding Light={StaticResource UserStrokeLight}, Dark=#33FFFFFF}" BorderWidth="1" />
                    </VerticalStackLayout>

                    <!-- PASUL 3: Resetare Parola -->
                    <VerticalStackLayout x:Name="Step3View" Spacing="24" IsVisible="False">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Pasul 3 din 3" FontFamily="Hanken Grotesk" FontSize="14" TextColor="{StaticResource UserPrimary}" FontAttributes="Bold" />
                            <Label Text="Alege o nouă parolă pentru contul tău." FontFamily="Hanken Grotesk" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" />
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Noua parolă" FontFamily="Hanken Grotesk" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource UserSurfaceStrongLight}, Dark=#0DFFFFFF}" Stroke="{AppThemeBinding Light={StaticResource UserStrokeLight}, Dark=#1AFFFFFF}" StrokeThickness="1" Padding="16,0" HeightRequest="48" StrokeShape="RoundRectangle 12">
                                <Entry x:Name="NewPasswordEntry" Placeholder="Minim 8 caractere" IsPassword="True" ReturnType="Next" TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" PlaceholderColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark=#80ffffff}" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Confirmă parola" FontFamily="Hanken Grotesk" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource UserSurfaceStrongLight}, Dark=#0DFFFFFF}" Stroke="{AppThemeBinding Light={StaticResource UserStrokeLight}, Dark=#1AFFFFFF}" StrokeThickness="1" Padding="16,0" HeightRequest="48" StrokeShape="RoundRectangle 12">
                                <Entry x:Name="ConfirmPasswordEntry" Placeholder="Repetă parola" IsPassword="True" ReturnType="Done" TextColor="{AppThemeBinding Light={StaticResource UserTextLight}, Dark=White}" PlaceholderColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark=#80ffffff}" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>
                        
                        <Button x:Name="ResetPasswordButton" Text="Schimbă parola" Clicked="OnResetPasswordClicked" BackgroundColor="{StaticResource UserPrimary}" TextColor="White" FontFamily="Hanken Grotesk" FontAttributes="Bold" CornerRadius="12" HeightRequest="48" />
                    </VerticalStackLayout>

                </Grid>
            </Border>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                <Label Text="Înapoi la" FontFamily="Hanken Grotesk" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource UserMutedLight}, Dark={StaticResource UserMutedDark}}" VerticalOptions="Center" />
                <Label Text="Autentificare" FontFamily="Hanken Grotesk" FontSize="14" TextColor="{StaticResource UserPrimary}" FontAttributes="Bold" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackToLoginTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>
