<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClimaOS_Desktop.Views.RegisterPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0b0f19">

    <Grid>
        <!-- Atmospheric Background -->
        <BoxView>
            <BoxView.Background>
                <RadialGradientBrush Center="0.5, 0.5" Radius="0.8">
                    <GradientStop Color="#001831" Offset="0.0" />
                    <GradientStop Color="#141313" Offset="0.5" />
                    <GradientStop Color="#0e0e0e" Offset="1.0" />
                </RadialGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Main Content (Centered) -->
        <VerticalStackLayout Spacing="32" Padding="26,42" VerticalOptions="Center" HorizontalOptions="Center">

            <!-- Logo & Title -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Label Text="☁️" FontSize="36" TextColor="White" VerticalOptions="Center"/>
                    <Label Text="ClimaOS" FontSize="36" FontFamily="Hanken Grotesk" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="Creează un cont nou" FontSize="15" FontFamily="Hanken Grotesk" TextColor="#c4c7c8" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Glassmorphism Card -->
            <Border BackgroundColor="#0DFFFFFF" Stroke="#1AFFFFFF" StrokeThickness="1" Padding="40" StrokeShape="RoundRectangle 24" WidthRequest="460">
                <VerticalStackLayout Spacing="24">

                    <VerticalStackLayout Spacing="16">
                        <Label Text="Înregistrare" FontFamily="Hanken Grotesk" FontSize="24" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Completează datele de mai jos." FontFamily="Hanken Grotesk" FontSize="14" TextColor="#c4c7c8" />
                    </VerticalStackLayout>

                    <!-- Form Fields -->
                    <VerticalStackLayout Spacing="20">
                        
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Nume" FontFamily="Hanken Grotesk" FontSize="13" TextColor="#c4c7c8" />
                            <Border BackgroundColor="#0DFFFFFF" Stroke="#1AFFFFFF" StrokeThickness="1" Padding="16,0" HeightRequest="48" StrokeShape="RoundRectangle 12">
                                <Entry x:Name="NameEntry" Placeholder="Prenume Nume" ReturnType="Next" TextColor="White" PlaceholderColor="#80ffffff" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Email" FontFamily="Hanken Grotesk" FontSize="13" TextColor="#c4c7c8" />
                            <Border BackgroundColor="#0DFFFFFF" Stroke="#1AFFFFFF" StrokeThickness="1" Padding="16,0" HeightRequest="48" StrokeShape="RoundRectangle 12">
                                <Entry x:Name="EmailEntry" Placeholder="nume@exemplu.com" Keyboard="Email" ReturnType="Next" TextColor="White" PlaceholderColor="#80ffffff" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Parolă" FontFamily="Hanken Grotesk" FontSize="13" TextColor="#c4c7c8" />
                            <Border BackgroundColor="#0DFFFFFF" Stroke="#1AFFFFFF" StrokeThickness="1" Padding="16,0" HeightRequest="48" StrokeShape="RoundRectangle 12">
                                <Entry x:Name="PasswordEntry" Placeholder="Minim 8 caractere" IsPassword="True" ReturnType="Next" TextColor="White" PlaceholderColor="#80ffffff" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Confirmă parola" FontFamily="Hanken Grotesk" FontSize="13" TextColor="#c4c7c8" />
                            <Border BackgroundColor="#0DFFFFFF" Stroke="#1AFFFFFF" StrokeThickness="1" Padding="16,0" HeightRequest="48" StrokeShape="RoundRectangle 12">
                                <Entry x:Name="ConfirmPasswordEntry" Placeholder="Repetă parola" IsPassword="True" ReturnType="Done" Completed="OnConfirmCompleted" TextColor="White" PlaceholderColor="#80ffffff" BackgroundColor="Transparent" FontSize="14" FontFamily="Hanken Grotesk" VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Register Button -->
                    <Button Text="Creează cont" Clicked="OnCreateAccountClicked" BackgroundColor="#4b8eff" TextColor="#00285c" FontFamily="Hanken Grotesk" FontAttributes="Bold" CornerRadius="12" HeightRequest="48" Margin="0,8,0,0" />

                    <!-- Link to Login -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,8,0,0">
                        <Label Text="Ai deja cont?" FontFamily="Hanken Grotesk" FontSize="14" TextColor="#c4c7c8" VerticalOptions="Center" />
                        <Label Text="Autentifică-te" FontFamily="Hanken Grotesk" FontSize="14" TextColor="#4b8eff" FontAttributes="Bold" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackToLoginTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>

