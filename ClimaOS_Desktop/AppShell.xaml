<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ClimaOS_Desktop.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:ClimaOS_Desktop.Pages"
    xmlns:admin="clr-namespace:ClimaOS_Desktop.Pages.Admin"
    Title="ClimaOS"
    FlyoutBehavior="Disabled">

    <ShellContent
        Title="Autentificare"
        ContentTemplate="{DataTemplate pages:LoginPage}"
        Route="LoginPage" />

    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate pages:DashboardPage}"
        Route="DashboardPage" />

    <ShellContent
        Title="Administrator"
        ContentTemplate="{DataTemplate admin:AdminDashboardPage}"
        Route="AdminDashboardPage" />

</Shell>
