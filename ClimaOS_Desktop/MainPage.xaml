<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClimaOS_Desktop.MainPage"
             BackgroundColor="#0B1120"> <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30,50" VerticalOptions="Center">

            <Label Text="☁️ ClimaOS"
                   FontSize="40"
                   FontAttributes="Bold"
                   TextColor="#3B82F6"
                   HorizontalOptions="Center" />

            <Label Text="Autentificare"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />
                   
            <Label Text="Introdu datele pentru a accesa contul tău"
                   FontSize="14"
                   TextColor="#94A3B8"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <Border Stroke="#1E293B"
                    StrokeThickness="2"
                    BackgroundColor="#0F172A"
                    Padding="25"
                    Margin="20,0"
                    StrokeShape="RoundRectangle 15">

                <VerticalStackLayout Spacing="20">
                    
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Adresă de email" TextColor="#E2E8F0" FontSize="14" FontAttributes="Bold"/>
                        <Entry x:Name="EmailEntry" 
                               Placeholder="nume@exemplu.com"
                               PlaceholderColor="#475569"
                               TextColor="White"
                               BackgroundColor="#1E293B"
                               Keyboard="Email" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Parolă" TextColor="#E2E8F0" FontSize="14" FontAttributes="Bold"/>
                        <Entry x:Name="PasswordEntry" 
                               Placeholder="••••••••"
                               PlaceholderColor="#475569"
                               TextColor="White"
                               BackgroundColor="#1E293B"
                               IsPassword="True" /> </VerticalStackLayout>

                    <Button Text="Autentificare"
                            BackgroundColor="#3B82F6"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="50"
                            Margin="0,15,0,0"
                            Clicked="OnLoginClicked"/>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                        <Label Text="Nu ai cont?" TextColor="#94A3B8" />
                        <Label Text="Creează cont" TextColor="#3B82F6" FontAttributes="Bold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>